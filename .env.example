# LLM API Keys
GOOGLE_API_KEY=your_gemini_api_key_here

# LLM Routing (Triage) Configuration
# ---------------------------------------------------------
# Fast Tier: Used for query expansion, summaries, and small tasks.
# Recommended: gemini-1.5-flash or lfm2.5:1.2b (Ollama)
LLM_FAST_PROVIDER=Gemini
LLM_FAST_MODEL=gemini-1.5-flash

# Smart Tier: Used for final RAG synthesis and complex analysis.
# Recommended: gemini-1.5-pro or huihui-gpt-oss-20b (Local)
LLM_SMART_PROVIDER=Gemini
LLM_SMART_MODEL=gemini-1.5-pro

# Local URLs (Only used if provider is 'Local (Ollama)' or 'Local (LM Studio)')
LLM_FAST_URL=http://localhost:11434/v1
LLM_SMART_URL=http://localhost:1234/v1

# CORS 允許來源（逗號分隔，留空則預設允許 localhost:3000,8501）
BACKEND_CORS_ORIGINS=

# Rate Limiting（slowapi 格式）
RATE_LIMIT_DEFAULT=30/minute

# 上傳檔案大小限制 (MB)
MAX_UPLOAD_SIZE_MB=50
